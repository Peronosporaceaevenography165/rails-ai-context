{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/frontend/*"],
      "@components/*": ["app/frontend/components/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["app/frontend/**/*"],
  "exclude": ["node_modules"]
}
