<!DOCTYPE html>
<html lang="en">
<head>
  <title>TestApp</title>
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>
<body>
  <header role="banner">
    <nav aria-label="Main navigation">
      <%= link_to "Home", root_path if respond_to?(:root_path) %>
    </nav>
  </header>

  <main role="main" id="main-content" data-turbo-permanent>
    <%= yield %>
  </main>

  <footer role="contentinfo">
    <p>&copy; TestApp</p>
  </footer>
</body>
</html>
